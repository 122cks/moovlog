# .env.example — 복사해서 .env.local로 사용하세요
# GitHub Pages 배포 시 GitHub Secrets에 동일한 키 이름으로 등록

VITE_GEMINI_KEY=your_gemini_api_key_here

VITE_TYPECAST_KEY=your_typecast_key_1
VITE_TYPECAST_KEY_2=your_typecast_key_2
VITE_TYPECAST_KEY_3=your_typecast_key_3

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_APP_ID=your_firebase_app_id
