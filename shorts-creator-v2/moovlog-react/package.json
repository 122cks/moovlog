{
  "name": "moovlog-shorts-creator",
  "version": "2.37",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node --input-type=module -e \"import{copyFileSync}from'fs';for(const f of['manifest.json','icon-192.png','icon-512.png','sw.js']){try{copyFileSync('public/'+f,'dist/'+f);console.log('copied',f)}catch(e){console.warn('skip:',f)}}\"",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "firebase": "^10.12.2",
    "mp4-muxer": "^5.1.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "webm-muxer": "^3.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "gh-pages": "^6.1.1",
    "vite": "^5.3.0"
  }
}
