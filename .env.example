# .env.example — 무브먼트 Shorts Creator 환경 변수 템플릿
#
# 실제 사용 시: 이 파일을 .env 로 복사한 후 값을 채워 넣으세요.
#   cp .env.example .env
#
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore 확인)
# ─────────────────────────────────────────────────────────────────

# ── Firebase (https://console.firebase.google.com → 프로젝트 설정) ──
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── Google Gemini AI (https://aistudio.google.com/app/apikey) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── Android AdMob (https://admob.google.com) ──
ADMOB_APP_ID=
ADMOB_BANNER_ID=

# ── 개발 환경 ──
NODE_ENV=development
