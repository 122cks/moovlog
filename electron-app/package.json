{
  "name": "moovlog-electron",
  "version": "2.81.0",
  "description": "무브먼트 Shorts Creator — 데스크탑 설치형 앱 (로컬 FFmpeg 연동)",
  "main": "main.js",
  "author": "122cks",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build:win": "cross-env WIN_CSC_LINK= CSC_LINK= CSC_IDENTITY_AUTO_DISCOVERY=false npx electron-builder@26.8.1 --win portable",
    "build:win-installer": "cross-env WIN_CSC_LINK= CSC_LINK= CSC_IDENTITY_AUTO_DISCOVERY=false npx electron-builder@26.8.1 --win nsis",
    "build:mac": "npx electron-builder@26.8.1 --mac dmg",
    "clean": "node -e \"require('fs').rmSync('./dist-electron',{recursive:true,force:true})\"",
    "build:clean": "npm run clean && npm run build:win-installer",
    "build:fresh": "node -e \"require('fs').rmSync('./dist-electron',{recursive:true,force:true});\" && npm run build:win-installer",
    "reinstall": "node -e \"require('fs').rmSync('./node_modules',{recursive:true,force:true});require('fs').rmSync('./package-lock.json',{force:true});\" && npm install"
  },
  "dependencies": {
    "electron-updater": "^6.3.4",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.moovlog.desktop",
    "productName": "무브먼트 Shorts Creator",
    "copyright": "Copyright © 2026 Moovlog",
    "electronVersion": "30.5.1",
    "npmRebuild": false,
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "../ffmpeg-2026-04-06-git-7fd2be97b9-full_build/ffmpeg-2026-04-06-git-7fd2be97b9-full_build/bin",
        "to": "ffmpeg-bin",
        "filter": [
          "ffmpeg.exe",
          "ffprobe.exe"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Moovlog Shorts Creator",
      "artifactName": "Moovlog-${version}-Setup.exe",
      "language": "1042",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "requestedExecutionLevel": "highestAvailable"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video"
    },
    "publish": {
      "provider": "github",
      "owner": "122cks",
      "repo": "moovlog"
    }
  }
}
