{
  "name": "moovlog-electron",
  "version": "2.72.0",
  "description": "무브먼트 Shorts Creator — 데스크탑 설치형 앱 (로컬 FFmpeg 연동)",
  "main": "main.js",
  "author": "122cks",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build:win": "electron-builder --win portable",
    "build:win-installer": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.moovlog.desktop",
    "productName": "무브먼트 Shorts Creator",
    "copyright": "Copyright © 2026 Moovlog",
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "../ffmpeg-2026-04-06-git-7fd2be97b9-full_build/ffmpeg-2026-04-06-git-7fd2be97b9-full_build/bin",
        "to": "ffmpeg-bin",
        "filter": [
          "ffmpeg.exe",
          "ffprobe.exe"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../shorts-creator-v2/moovlog-react/public/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "../shorts-creator-v2/moovlog-react/public/icon-512.png"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video"
    }
  }
}
